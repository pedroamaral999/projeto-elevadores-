#include <Servo.h>

const int botoesAndar[4]  = {A0, A1, A2, A3};   
const int botoesCab1[4]   = {6, 7, 8, 9};       
const int botoesCab2[4]   = {10, 11, 12, 13};    

const int pinoServo1 = 3;
const int pinoServo2 = 5;

Servo servoCab1;
Servo servoCab2;

const int posicoesAndar[4] = {0, 60, 120, 180};

int andarAtual1 = 0; 
int andarAtual2 = 0;

int destino1 = 0;
int destino2 = 0;

bool emMovimento1 = false;
bool emMovimento2 = false;

int direcao1 = 0; 
int direcao2 = 0;

bool chamadasAndar[4] = {false, false, false, false};
bool chamadasCab1[4]  = {false, false, false, false};
bool chamadasCab2[4]  = {false, false, false, false};

unsigned long tempoParada1 = 0;
unsigned long tempoParada2 = 0;
bool aguardando1 = false;
bool aguardando2 = false;

void setup() {
  for(int i = 0; i < 4; i++) {
    pinMode(botoesAndar[i], INPUT_PULLUP);
    pinMode(botoesCab1[i], INPUT_PULLUP);
    pinMode(botoesCab2[i], INPUT_PULLUP);
  }
  
  servoCab1.attach(pinoServo1);
  servoCab2.attach(pinoServo2);
  
  servoCab1.write(posicoesAndar[andarAtual1]);
  servoCab2.write(posicoesAndar[andarAtual2]);
}

void loop() {
  lerBotoes();
  atualizarElevador1();
  atualizarElevador2();
  delay(50);
}

void lerBotoes() {
  for(int i = 0; i < 4; i++) {
    if(digitalRead(botoesAndar[i]) == LOW)  chamadasAndar[i] = true;
    if(digitalRead(botoesCab1[i]) == LOW)   chamadasCab1[i] = true;
    if(digitalRead(botoesCab2[i]) == LOW)   chamadasCab2[i] = true;
  }
}

void atualizarElevador1() {
 
  if(aguardando1) {
    if(millis() - tempoParada1 >= 5000) { 
      aguardando1 = false;
    }
    return; 
  }

  if(!emMovimento1) {
    int melhorDist = 999;
    int proximoDestino = -1;
    
    for(int i = 0; i < 4; i++) {
      if(chamadasCab1[i] || chamadasAndar[i]) {
        int dist = abs(andarAtual1 - i);
        if(dist < melhorDist) {
          melhorDist = dist;
          proximoDestino = i;
        }
      }
    }
    
    if(proximoDestino != -1) {
      bool escolher = true;
      
      if(chamadasAndar[proximoDestino] && !chamadasCab1[proximoDestino]) {
        if(!emMovimento2) {
          int dist2 = abs(andarAtual2 - proximoDestino);
          if(dist2 < melhorDist) escolher = false; 
        } else {

          if((direcao2 == 1 && proximoDestino > andarAtual2 && proximoDestino <= destino2) ||
             (direcao2 == -1 && proximoDestino < andarAtual2 && proximoDestino >= destino2)) {
            escolher = false;
          }
        }
      }
      
      if(escolher) {
        destino1 = proximoDestino;
        emMovimento1 = true;
        direcao1 = (destino1 > andarAtual1) ? 1 : ((destino1 < andarAtual1) ? -1 : 0);
        
        if(destino1 == andarAtual1) {
          emMovimento1 = false;
          direcao1 = 0;
          aguardando1 = true;
          tempoParada1 = millis();
          chamadasCab1[andarAtual1] = false;
          chamadasAndar[andarAtual1] = false;
        }
      }
    }
  }

  if(emMovimento1) {
    int posAlvo = posicoesAndar[destino1];
    int posAtual = servoCab1.read();

    if(posAtual < posAlvo)       servoCab1.write(posAtual + 1);
    else if(posAtual > posAlvo)  servoCab1.write(posAtual - 1);

    for(int i = 0; i < 4; i++) {
      if(posAtual == posicoesAndar[i]) {
        andarAtual1 = i;

        bool deveParar = false;
        if(andarAtual1 == destino1) {
          deveParar = true; 
        } else {
          if(chamadasCab1[andarAtual1]) deveParar = true; 
          if(chamadasAndar[andarAtual1]) {
           
            if((direcao1 == 1 && destino1 > andarAtual1) || (direcao1 == -1 && destino1 < andarAtual1)) {
              deveParar = true;
            }
          }
        }

        if(deveParar) {
          chamadasCab1[andarAtual1] = false;
          chamadasAndar[andarAtual1] = false;
          aguardando1 = true;
          tempoParada1 = millis();
          
          if(andarAtual1 == destino1) {
            emMovimento1 = false;
            direcao1 = 0;
          }
          return;
        }
      }
    }
  }
}

